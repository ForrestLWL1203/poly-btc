# credentials / secrets — NEVER commit (public repo)
secret/
*.pem
*.key
.env
.env.*

# local collection data
data/
*.db
*.db-wal
*.db-shm

# dashboard runtime vendor libs: React/ReactDOM are required by committed dashboard/web/index.html.
# Keep Babel ignored because production uses precompiled dashboard/web/app.js.
dashboard/web/vendor/*
!dashboard/web/vendor/
!dashboard/web/vendor/react-18.3.1.production.min.js
!dashboard/web/vendor/react-dom-18.3.1.production.min.js

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/

# private strategy notes — remove this line if you want it public
hyper/docs/
btc5min-handoff.md
monitor-plan.md
findings.md

# private operational runbook (contains VPS host / ops) — never public
CLAUDE.md

# macOS
.DS_Store
